#!/bin/bash

DIRS=(
    "$HOME/Documents"
    "$HOME/Downloads"
)

# If file passed as argument, use it directly
if [[ $# -eq 1 ]]; then
    selected="$1"
else
    selected=$(rg --files "${DIRS[@]}" |
        grep -Ei '\.(pdf|epub|djvu)$' |
        sed "s|^$HOME/||" |
        fzf --margin=10%)

    [[ $selected ]] && selected="$HOME/$selected"
fi

# Exit if nothing selected
[[ -z "$selected" ]] && exit 0

# Open in new tmux window
if tmux info &>/dev/null; then
    tmux new-window -d zathura "$selected"
else
    tmux new-session -d -s default zathura "$selected"
fi
